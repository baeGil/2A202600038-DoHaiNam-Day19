# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=your_chat_model_name
LLM_TEMPERATURE=0.0

# Documents
DOCUMENT_PATHS=data/wiki100k_samples/01_12.md
CHUNK_SIZE=1400
CHUNK_OVERLAP=180
MAX_DOCUMENTS=1

# Retrieval tuning
FLAT_TOP_K=5
GRAPH_SEED_K=5
GRAPH_HOPS=2
GRAPH_NEIGHBOR_LIMIT_PER_NODE=20
GRAPH_CHUNK_BOOST_K=5
MAX_CONTEXT_CHUNKS=8
MAX_CONTEXT_CHARS=12000
ANSWER_STYLE=concise, accurate, and cite supporting evidence

# Milvus local
# Milvus runs in Docker Compose on localhost.
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_COLLECTION_NAME=graph_rag_chunks
MILVUS_METRIC_TYPE=COSINE
MILVUS_DROP_EXISTING_COLLECTION=false

# Jina Embeddings
JINA_API_KEY=your_jina_api_key_here
JINA_EMBEDDING_MODEL=jina_model_name_here
JINA_API_BASE_URL=https://api.jina.ai/v1/embeddings
JINA_NORMALIZED=true
JINA_EMBEDDING_TYPE=float
JINA_TRUNCATE=true

# Graph build tuning
MAX_ENTITIES_PER_CHUNK=8
MAX_RELATIONSHIPS_PER_CHUNK=10
EXTRACTION_CACHE_PATH=.cache_graph_extraction.json
REBUILD_NEO4J=false
TRUNCATE_EXISTING_GRAPH=false
NEO4J_FULLTEXT_INDEX_NAME=entity_fulltext
BUILD_MANIFEST_PATH=.cache_build_manifest.json
SKIP_EXISTING_BUILD=true

# Neo4j
NEO4J_IMAGE=neo4j:5-community
NEO4J_AUTH=neo4j/password
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j

# Optional legacy alias used by some setups
NEO4J_USER=neo4j

# Docker images
ETCD_IMAGE=quay.io/coreos/etcd:v3.5.5
MINIO_IMAGE=minio/minio:RELEASE.2023-07-07T07-13-57Z
MILVUS_IMAGE=milvusdb/milvus:v2.5.14
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
ATTU_IMAGE=zilliz/attu:v2.5.10
ATTU_PORT=3000
MILVUS_DATABASE=default
